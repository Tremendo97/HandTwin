# Plugins
Plugins/**/Binaries/
Plugins/**/Intermediate/

# Ignore precompiled headers
*.pch
*.gch

# Ignore Visual Studio generated caches
*.VC.db
*.VC.opendb

# Ignore temporary files
*.log
*.tmp
*.cache
*.pdb
*.ipch
*.obj
*.opensdf

# Ignore auto-generated config files
Saved/*

# Optionally ignore user preferences
*.user
*.userprefs

# Keep only essential files
!Content/**/Config/**.ini
!Source/**/Config/**.ini